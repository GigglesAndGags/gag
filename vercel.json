{
  "buildCommand": "cd frontend && node build.js && curl -o ../dist/vendor/ethers.umd.min.js https://cdnjs.cloudflare.com/ajax/libs/ethers/6.13.4/ethers.umd.min.js",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors https://*.warpcast.com https://*.farcaster.xyz https://*.base.org https://*.coinbase.com https://base.dev 'self'"
        }
      ]
    }
  ]
}
